{
  "version": 2,
  "builds": [
    {
      "src": "site/**",
      "use": "@vercel/static"
    },
    {
      "src": "dashboard/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/dashboard",
      "dest": "/site/index.html"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "/site/index.html"
    },
    {
      "src": "/js/(.*)",
      "dest": "/dashboard/js/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/dashboard/css/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/dashboard/manifest.json"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://xactions-api.up.railway.app/api/$1"
    },
    {
      "src": "/tutorials/unfollow(.html)?",
      "dest": "/dashboard/tutorials/unfollow.html"
    },
    {
      "src": "/tutorials/automation(.html)?",
      "dest": "/dashboard/tutorials/automation.html"
    },
    {
      "src": "/tutorials/monitoring(.html)?",
      "dest": "/dashboard/tutorials/monitoring.html"
    },
    {
      "src": "/tutorials/scrapers-full(.html)?",
      "dest": "/dashboard/tutorials/scrapers-full.html"
    },
    {
      "src": "/tutorials/scrapers(.html)?",
      "dest": "/dashboard/tutorials/scrapers.html"
    },
    {
      "src": "/tutorials/mcp(.html)?",
      "dest": "/dashboard/tutorials/mcp.html"
    },
    {
      "src": "/tutorials/communities(.html)?",
      "dest": "/dashboard/tutorials/communities.html"
    },
    {
      "src": "/tutorials(.html)?",
      "dest": "/dashboard/tutorials/index.html"
    },
    {
      "src": "/login",
      "dest": "/site/index.html"
    },
    {
      "src": "/pricing",
      "dest": "/dashboard/docs.html"
    },
    {
      "src": "/about",
      "dest": "/dashboard/about.html"
    },
    {
      "src": "/docs",
      "dest": "/dashboard/docs.html"
    },
    {
      "src": "/privacy",
      "dest": "/dashboard/privacy.html"
    },
    {
      "src": "/terms",
      "dest": "/dashboard/terms.html"
    },
    {
      "src": "/features",
      "dest": "/dashboard/features.html"
    },
    {
      "src": "/run",
      "dest": "/dashboard/run.html"
    },
    {
      "src": "/admin",
      "dest": "/site/index.html"
    },
    {
      "src": "/ai",
      "dest": "/dashboard/ai.html"
    },
    {
      "src": "/ai-api",
      "dest": "/dashboard/ai-api.html"
    },
    {
      "src": "/mcp",
      "dest": "/dashboard/mcp.html"
    },
    {
      "src": "/analytics",
      "dest": "/site/index.html"
    },
    {
      "src": "/automations",
      "dest": "/site/index.html"
    },
    {
      "src": "/monitor",
      "dest": "/site/index.html"
    },
    {
      "src": "/unfollowers",
      "dest": "/site/index.html"
    },
    {
      "src": "/workflows",
      "dest": "/site/index.html"
    },
    {
      "src": "/thread/(.*)",
      "dest": "/dashboard/thread.html"
    },
    {
      "src": "/thread",
      "dest": "/dashboard/thread.html"
    },
    {
      "src": "/video",
      "dest": "/dashboard/video.html"
    },
    {
      "src": "/faq",
      "dest": "/dashboard/faq.html"
    },
    {
      "src": "/404",
      "dest": "/dashboard/404.html"
    },
    {
      "src": "/(.*)",
      "dest": "/site/$1",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "X-XSS-Protection": "1; mode=block"
      }
    }
  ]
}